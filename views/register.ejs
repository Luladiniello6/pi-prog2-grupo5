<!DOCTYPE html>
<html lang="es">
<!-- Include Head -->
<%- include('./partials/head') %>

<body>
	<%- include('./partials/header') %>

	<!-- Novedades -->
	<div class="container products-wrapper">
		<div class="row">
			<div class="col-12">
				<h2 class="products-title">Registrate</h2>
			</div>
			<!-- Show the "ultimos" products -->
			<h2 class="col-12"> 
        <form class="form-register" action="/users/login" method="get">
            <div>
                <label for="username">Mail: </label>
                <input type="text" id="email" name="email" >
            </div>

            <div>
                <label for="contraseña">Contraseña</label>
                <input type="password" id="password" name="password" >
            </div>

            <div>
                <label for="contraseña2">Repetir Contraseña: </label>
                <input type="password" id="password2" name="password2" >
            </div>


            <div class="botones-register">
                <button type="submit">Registrarse</button>
            </div>

            <div>
                <a href="/users/login">Ya tengo cuenta</a>
            </div>



        </form>
			</h2>


	<!-- footer -->
	<%- include('./partials/footer') %>
	<!-- /footer -->
</body>

</html>